# docker/.env.docker — local config for the prod-equivalent WS tier (FLO-347).
#
# Copy to `docker/.env.docker` and fill in (NEVER commit the filled copy):
#   cp docker/.env.docker.example docker/.env.docker
# docker-compose.yml + scripts/dev/docker-ws-tier.sh read this via `env_file`.
# Generate a strong local password, e.g.:
#   python3 -c "import secrets; print(secrets.token_urlsafe(18))"

# MariaDB superuser password Frappe's `bench new-site` uses over TCP.
MARIADB_ROOT_PASSWORD=changeme-generate-a-strong-local-password

# Frappe site name + Administrator password. The smoke connects the per-site
# realtime namespace `/<site>`, so this MUST match load/config.js -> ws.site
# (default flock_os.localhost).
SITE_NAME=flock_os.localhost
SITE_ADMIN_PASSWORD=changeme-generate-a-strong-local-password

# socketio worker count for the scaled tier (the §8 connection-setup wall is a
# single-event-loop wall, so N >= 4 spreads the 15k handshakes). Override at
# runtime: `FLOCK_SIO_WORKERS=8 scripts/dev/docker-ws-tier.sh up`.
FLOCK_SIO_WORKERS=4

# gunicorn web workers (auth callback + producer traffic). 4 is plenty for the
# gate (the auth cache means ~1 get_user_info per session, not per connection).
GUNICORN_WORKERS=4

# Host ports the k6 client connects to. Defaults match load/config.js so k6
# needs no override: WS_BASE_URL=ws://flock_os.localhost:9000, BASE_URL=http://...:8000.
WEBSERVER_HOST_PORT=8000
WS_LB_HOST_PORT=9000

# Image tag (the tier builds once on first `up`; reuse the tag to skip rebuilds).
FLOCK_IMAGE=flock-os-frappe:ws-tier

# k6 gate parameters (docker-ws-tier.sh gate). The full §8 acceptance bar:
FLOCK_GATE_VUS=15000
FLOCK_GATE_DURATION_SEC=120
