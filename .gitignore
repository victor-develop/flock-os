# --- Frappe / bench ---
bench/
sites/common_site_config.json
sites/*/private.pem
sites/*/public.pem
sites/assets/
logs/
*.pyc
__pycache__/
*.egg-info/
.frappe/
# node
node_modules/
# env
.env
.env.*
!.env.example
# secrets (FLO-248: SOPS+age). Track ONLY the encrypted ciphertext bundles
# (secrets/*.enc.yaml); ignore every plaintext form + every age PRIVATE key.
# The private key is the one true secret — it must NEVER be committed.
secrets/*.yaml
secrets/*.yml
!secrets/*.enc.yaml
!secrets/*.enc.yml
secrets/.age-key
secrets/.age-key.*
secrets/*.key
secrets/keys/
*.age.key
# rendered plaintext env (render-secrets.sh --out) — transient, never tracked
secrets/*.env
*.rendered.env
!docker/.env.docker.example
# docker prod-equivalent WS tier: generated runtime + local config (FLO-347)
docker/.runtime/
docker/.env.docker
# python tooling venv (FLO-88: worktree .venv is a symlink -> shows as
# untracked without this; main-repo .venv hides via its internal .gitignore)
.venv
# per-slice worktree park (FLO-88) — never tracked, lives as a repo sibling
/flock-os-worktrees/
# os
.DS_Store
# test/coverage artifacts (FLO-21 coverage gate)
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/
# paperclip local artifacts (keep tracked: .paperclip/)
