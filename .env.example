# Copy this file to `.env` (gitignored) and fill in local-only secrets.
#   cp .env.example .env
#
# .env is NEVER committed. scripts/bootstrap-db.sh and scripts/bootstrap.sh
# read it at runtime. No secret belongs in the repo or in agent prompts.
#
# Generate a strong local password, e.g.:
#   python3 -c "import secrets; print(secrets.token_urlsafe(18))"

# Password for the TCP-accessible MariaDB superuser (frappe_root) that Frappe's
# `bench new-site` uses to create the per-site database + user.
MARIADB_ROOT_PASSWORD=changeme-generate-a-strong-local-password

# Where the bench runtime lives. Kept OUTSIDE the repo so the tracked tree
# stays clean (only the flock_os app source + CI + scripts are committed).
BENCH_DIR=/Users/mac/opencode-workspace-default/flock-os-bench

# Local dev site name (Frappe convention: <name>.localhost).
SITE_NAME=flock_os.localhost

# Administrator password for the Frappe site (the `Administrator` user).
SITE_ADMIN_PASSWORD=changeme-generate-a-strong-local-password

# ---------------------------------------------------------------------------- #
# CEO heartbeat monitoring (FLO-266).
# Used by scripts/dev/ceo-heartbeat-monitor.py. PAPERCLIP_API_URL /
# PAPERCLIP_API_KEY / PAPERCLIP_COMPANY_ID are auto-injected by a Paperclip
# run; set the values below when running the monitor standalone (cron/launchd).
# Full runbook: docs/operations/ceo-heartbeat-monitoring.md
# ---------------------------------------------------------------------------- #

# The Paperclip control-plane API base URL.
PAPERCLIP_API_URL=https://paperclip.example.test

# Short-lived run JWT (auto-injected inside a heartbeat). For a standalone
# cron job, provision a long-lived API key and store it outside the repo.
PAPERCLIP_API_KEY=

# Company id the CEO agent lives in.
PAPERCLIP_COMPANY_ID=

# CEO agent + heartbeat routine to monitor. FLO_CEO_AGENT_ID is required;
# FLO_CEO_ROUTINE_ID is auto-discovered (the active routine assigned to the
# CEO) but can be pinned to skip the discovery call.
FLO_CEO_AGENT_ID=
FLO_CEO_ROUTINE_ID=

# Silence thresholds (minutes). Incident analysis target: warn at 15, escalate
# at 30. See docs/architecture/ceo-silent-run-analysis.md.
FLO_CEO_MONITOR_WARN_MIN=15
FLO_CEO_MONITOR_CRIT_MIN=30

# Recent-run window the monitor inspects each scrape (trends + active-run check).
FLO_CEO_MONITOR_RUN_LIMIT=50

# Alert routing (used by --alert mode). Defaults to the Software Architect
# (the CEO's de-facto recovery owner until FLO-267 ships auto-restart). Rule #1:
# never page a human for what an agent could do.
FLO_CEO_MONITOR_ESCALATION_AGENT_ID=

# Parent + project for alert issues opened by the monitor. FLO_CEO_HEARTBEAT_ISSUE_ID
# is the CEO heartbeat issue (FLO-263) so alerts thread under the routine.
FLO_CEO_HEARTBEAT_ISSUE_ID=
PAPERCLIP_PROJECT_ID=
